---
import ButtonCenter from "./ButtonCenter.astro"
---

<div
  class="flex flex-wrap justify-around p-2 dark:text-white"
>
  <div
    class="flex flex-wrap items-center justify-center gap-8 text-center md:text-left"
  >

    <div class="flex flex-col gap-4">
      <h1
        class="overflow-hidden font-qsan text-5xl font-semibold md:animate-appearSlide md:whitespace-nowrap md:opacity-0"
        style="animation-delay: 0.2s"
      >
        I'm Tim
      </h1>
      <h2
        class="overflow-hidden font-qsan text-3xl md:animate-appearSlide md:whitespace-nowrap md:opacity-0"
        style="animation-delay: 0.7s"
      >
        Software Engineer, DevOps, SRE, and Home Lab Enthusiast + AI 👨🏼‍🔬
      </h2>
      <div
        class:list={[
          "py-4 md:animate-appearSlide md:whitespace-nowrap md:opacity-0",
        ]}
        style="animation-delay: 1.2s"
      >
        <a
          href="/projects"
          class:list={[
            "group",
            "inline-flex",
            "items-center",
            "gap-2",
            "rounded-full",
            "border",
            "border-teal-500/40",
            "bg-teal-500/10",
            "px-6",
            "py-3",
            "text-sm",
            "font-medium",
            "text-teal-300",
            "backdrop-blur-sm",
            "transition-all",
            "duration-300",
            "hover:border-teal-400/70",
            "hover:bg-teal-500/20",
            "hover:text-teal-200",
            "hover:shadow-[0_0_20px_rgba(20,184,166,0.25)]",
            "hover:scale-105",
          ]}
        >
          Checkout my projects!
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            class="transition-transform duration-300 group-hover:translate-x-1"
          >
            <path d="M5 12h14"/><path d="m12 5 7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </div>
</div>
