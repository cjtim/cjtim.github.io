---
import GitHubSvg from "../svgs/GitHubSvg.astro"
import LinkedIn from "../svgs/LinkedIn.astro"
import GmailSvg from "../svgs/GmailSvg.astro"

const socialMedias = [
  {
    icon: GitHubSvg,
    href: "https://github.com/cjtim",
    label: "GitHub",
  },
  {
    icon: LinkedIn,
    href: "https://www.linkedin.com/in/tim-jinna/",
    label: "LinkedIn",
  },
  {
    icon: GmailSvg,
    href: "mailto:jinnatim@gmail.com",
    label: "Email",
  },
]

const navLinks = [
  { label: "Tim Jinna", href: "/", isLogo: true },
  { label: "Projects", href: "/projects", isLogo: false },
]
---

<header
  class="sticky top-0 z-50 w-full"
>
  <nav class="container mx-auto flex items-center px-4 py-3">
    <!-- Nav links -->
    <div class="mr-auto flex items-center gap-1">
      {
        navLinks.map((link) => (
          <a
            href={link.href}
            data-navlink
            class:list={[
              "relative px-3 py-2 transition-colors duration-200",
              link.isLogo
                ? "text-lg font-bold text-white"
                : "text-sm font-medium text-gray-400 hover:text-white",
            ]}
          >
            {link.label}
            {!link.isLogo && (
              <span
                data-indicator
                class="absolute inset-x-3 -bottom-[1px] h-[2px] scale-x-0 rounded-full bg-teal-400 transition-transform duration-300 origin-left"
              />
            )}
          </a>
        ))
      }
    </div>

    <!-- Social icons -->
    <div class="flex items-center gap-3">
      {
        socialMedias.map((item) => (
          <a
            href={item.href}
            target="_blank"
            rel="noopener noreferrer"
            aria-label={item.label}
            class="flex h-8 w-8 items-center justify-center rounded-md fill-gray-400 text-gray-400 transition-all duration-200 hover:fill-teal-400 hover:text-teal-400 hover:bg-teal-400/10"
          >
            <item.icon />
          </a>
        ))
      }
    </div>
  </nav>
</header>

<script>
  function setActiveLink() {
    const path = document.location.pathname.split("/").slice(0, 2).join("/") || "/"
    document.querySelectorAll<HTMLAnchorElement>("a[data-navlink]").forEach((link) => {
      const indicator = link.querySelector<HTMLElement>("[data-indicator]")
      const isActive = link.getAttribute("href") === path
      if (isActive) {
        link.classList.remove("text-gray-400")
        link.classList.add("text-white")
        indicator?.classList.remove("scale-x-0")
      } else {
        indicator?.classList.add("scale-x-0")
      }
    })
  }

  setActiveLink()
</script>
